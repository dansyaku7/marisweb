// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  SUPERADMIN
  CLIENT
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
}

// Tipe template yang sudah dipecah berdasarkan intensi email
enum EmailTemplateType {
  EXPIRED_SINGLE    // Notif per satu alat yang mau habis
  EXPIRED_BULK      // Notif massal (Alert Expired)
  READY_SINGLE      // Notif per satu alat (Dokumen Selesai)
  READY_BULK        // Notif massal (Dokumen Selesai)
}

// ==========================================
// MODELS
// ==========================================

model Company {
  id        String   @id @default(uuid())
  name      String   @unique
  emailPic  String?
  namePic   String?  // Nama PIC (Person in Charge)
  phonePic  String?  // No HP PIC
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  equipments     Equipment[]
  emailLogs      EmailLog[]
  emailTemplates EmailTemplate[]

  @@map("companies")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(CLIENT)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("users")
}

model Equipment {
  id             String    @id @default(uuid())
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name           String
  location       String?
  permitNumber   String?
  serialNumber   String?
  inspectionDate DateTime
  expiryDate     DateTime

  area           String?
  brand          String?
  capacity       String?
  description    String?   @db.Text

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  isProsesDinas  Boolean   @default(true)

  suket          Suket[]
  laporan        Laporan[]
  emailLogs      EmailLog[]

  @@index([companyId])
  @@index([expiryDate])
  @@map("equipments")
}

model Suket {
  id          String    @id @default(uuid())
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  period      String
  fileUrl     String    @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([equipmentId])
  @@map("sukets")
}

model Laporan {
  id          String    @id @default(uuid())
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  period      String
  fileUrl     String    @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([equipmentId, period])
  @@index([equipmentId])
  @@map("laporans")
}

model EmailLog {
  id           String      @id @default(uuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  equipmentId  String
  equipment    Equipment   @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  status       EmailStatus @default(PENDING)
  sentAt       DateTime?
  errorMessage String?     @db.Text
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([companyId])
  @@index([status])
  @@map("email_logs")
}

model EmailTemplate {
  id          String            @id @default(uuid())
  companyId   String?           // NULL berarti template GLOBAL
  company     Company?          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        EmailTemplateType
  senderName  String            @default("M-Track Marusindo")
  subject     String            @db.Text
  introText   String            @db.Text
  footerText  String            @db.Text
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Constraint: Satu company cuma boleh punya satu template per tipe
  @@unique([companyId, type])
  @@index([companyId])
  @@map("email_templates")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@map("password_reset_tokens")
}